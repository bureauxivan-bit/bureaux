# ───────────── Database (Supabase / Neon / Railway Postgres) ─────────────
# Pooled connection (used by the app at runtime). For Supabase use the
# "Connection pooling" string (port 6543, pgbouncer=true).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrate). Supabase: port 5432.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ───────────── Supabase Storage (project image hosting) ─────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
# Service-role key is server-only — NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="..."
# Name of the public Storage bucket that holds project images.
SUPABASE_BUCKET="bureaux"

# ───────────── Admin auth (JWT in httpOnly cookie) ─────────────
# Long random string — generate with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# ───────────── Lead notifications ─────────────
TELEGRAM_BOT_TOKEN="123456:ABC-your-bot-token"
TELEGRAM_CHAT_ID="-1001234567890"

# ───────────── Visit analytics + server error notifications ─────────────
# Separate chat recommended so visit/error noise doesn't mix with sales leads.
# Reuse the bot above by leaving TELEGRAM_ANALYTICS_BOT_TOKEN empty, or register
# a second bot via @BotFather for a fully separate one. Empty = feature disabled.
TELEGRAM_ANALYTICS_BOT_TOKEN=""
TELEGRAM_ANALYTICS_CHAT_ID="-1009876543210"

# ───────────── Public site config ─────────────
NEXT_PUBLIC_SITE_URL="https://bureaux.example"
# Optional: Plausible / GA
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
