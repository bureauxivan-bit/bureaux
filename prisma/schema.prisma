generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectCategory {
  PRIVATE
  COMMERCIAL
  ARCHITECTURE
}

enum LeadType {
  ESTIMATE
  CONSULT
  GENERAL
}

model Project {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  year        Int
  category    ProjectCategory
  description String?
  areaM2      Int?
  location    String?
  isTop       Boolean         @default(false)
  order       Int             @default(0)
  images      ProjectImage[]
  coverId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectImage {
  id         String  @id @default(cuid())
  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storageKey String
  url        String
  alt        String?
  width      Int?
  height     Int?
  order      Int     @default(0)

  @@index([projectId])
}

model Service {
  id          String  @id @default(cuid())
  number      Int
  title       String
  description String?
  coverUrl    String?
  order       Int     @default(0)
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  role     String
  quote    String?
  photoUrl String?
  order    Int     @default(0)
}

model Review {
  id          String  @id @default(cuid())
  author      String
  projectName String?
  text        String
  isPublished Boolean @default(true)
  order       Int     @default(0)
}

model Faq {
  id       String @id @default(cuid())
  question String
  answer   String
  order    Int    @default(0)
}

model Lead {
  id              String              @id @default(cuid())
  // Site form fields
  name            String?
  phone           String?
  email           String?
  type            LeadType            @default(GENERAL)
  message         String?
  // Unified funnel
  source          String              @default("site")
  externalId      String?             @unique
  clientName      String?
  objectType      String?
  areaM2          Int?
  location        String?
  service         String?
  status          String              @default("new")
  lostReason      String?
  kpId            String?
  kp              KpProposal?         @relation(fields: [kpId], references: [id], onDelete: SetNull)
  lastClientMsgAt DateTime?
  pushSentAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  statusHistory   LeadStatusHistory[]

  @@index([source])
  @@index([status])
}

model LeadStatusHistory {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status    String
  changedAt DateTime @default(now())

  @@index([leadId])
}

model SiteSettings {
  id          String  @id @default("singleton")
  phone       String?
  email       String?
  telegram    String?
  instagram   String?
  facebook    String?
  behance     String?
  address     String?
  coordinates String?
  itemXUrl    String?
  heroImage   String?
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum ClientStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClientProjectType {
  PRIVATE
  COMMERCIAL
  ARCHITECTURE
}

model ClientUser {
  id             String            @id @default(cuid())
  name           String
  email          String            @unique
  passwordHash   String
  phone          String
  projectType    ClientProjectType @default(PRIVATE)
  projectName    String?
  projectDetails String?
  projectAddress String?
  projectCity    String?
  status         ClientStatus      @default(PENDING)
  adminNote      String?
  stages         ClientStage[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum StageStatus {
  PENDING
  ACTIVE
  DONE
}

model ClientStage {
  id               String                @id @default(cuid())
  clientId         String
  client           ClientUser            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stageIndex       Int
  status           StageStatus           @default(PENDING)
  note             String?
  clientApprovedAt DateTime?
  files            ClientStageFile[]
  rooms            ClientRoom[]
  specItems        ClientSpecItem[]
  revisions        ClientStageRevision[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([clientId, stageIndex])
  @@index([clientId])
}

model ClientStageFile {
  id         String      @id @default(cuid())
  stageId    String
  stage      ClientStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  name       String
  url        String
  storageKey String?
  createdAt  DateTime    @default(now())

  @@index([stageId])
}

model ClientRoom {
  id               String               @id @default(cuid())
  stageId          String
  stage            ClientStage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  name             String
  order            Int                  @default(0)
  clientApprovedAt DateTime?
  visualizations   ClientVisualization[]
  revisions        ClientRoomRevision[]

  @@index([stageId])
}

model ClientRoomRevision {
  id           String     @id @default(cuid())
  roomId       String
  room         ClientRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  text         String
  isFromClient Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([roomId])
}

model ClientStageRevision {
  id           String      @id @default(cuid())
  stageId      String
  stage        ClientStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  text         String
  isFromClient Boolean     @default(false)
  createdAt    DateTime    @default(now())

  @@index([stageId])
}

model ClientVisualization {
  id          String     @id @default(cuid())
  roomId      String
  room        ClientRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  url         String
  description String?
  order       Int        @default(0)

  @@index([roomId])
}

model KpProposal {
  id                 String    @id @default(cuid())
  code               String    @unique
  clientName         String
  objectType         String?
  areaM2             Int?
  location           String?
  service            String?
  priceDesign        Int?
  supervisionMonthly Int?
  services           Json?
  startDate          String?
  durationWeeks      String    @default("~12 тижнів")
  projectIds         String[]
  introText          String?
  validDays          Int       @default(14)
  status             String    @default("draft")
  viewCount          Int       @default(0)
  firstViewedAt      DateTime?
  ctaClickedAt       DateTime?
  sentAt             DateTime?
  viewedAt           DateTime?
  meetingAt          DateTime?
  contractAt         DateTime?
  declinedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  events             KpEvent[]
  leads              Lead[]
}

model KpEvent {
  id        String     @id @default(uuid())
  kpId      String
  kp        KpProposal @relation(fields: [kpId], references: [id], onDelete: Cascade)
  eventType String
  value     Int?
  createdAt DateTime   @default(now())

  @@index([kpId])
  @@index([kpId, eventType])
}

model Visit {
  id        String   @id @default(cuid())
  ip        String
  country   String?
  city      String?
  isp       String?
  device    String?
  os        String?
  browser   String?
  language  String?
  referrer  String?
  utm       String?
  page      String
  isNew     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ClientSpecItem {
  id       String      @id @default(cuid())
  stageId  String
  stage    ClientStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  category String?
  name     String
  quantity String?
  unit     String?
  note     String?
  order    Int         @default(0)

  @@index([stageId])
}
